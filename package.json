{
    "name": "@signalsafe/tree-spec-editor",
    "version": "0.2.2",
    "type": "module",
    "description": "Reusable TreeSpec graph editor (React Flow) and authoring helpers (no API or routing).",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SignalSafeSoftware/tree-spec-editor.git"
    },
    "bugs": {
        "url": "https://github.com/SignalSafeSoftware/tree-spec-editor/issues"
    },
    "homepage": "https://github.com/SignalSafeSoftware/tree-spec-editor#readme",
    "keywords": [
        "tree-spec",
        "react-flow",
        "editor",
        "graph-editor",
        "decision-tree",
        "react-bootstrap",
        "typescript",
        "signalsafe"
    ],
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "docs",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "typecheck": "tsc --noEmit",
        "pack:local": "npm pack --pack-destination ../../dist/reusable-npm",
        "release:check": "node ../../scripts/run-private-package-release-checks.mjs --mode prepublish",
        "release:verify": "node ../../scripts/run-private-package-release-checks.mjs --mode postpublish",
        "publish:preflight": "node ../../scripts/check-private-registry-preflight.mjs --scope @signalsafe",
        "publish:dry-run": "npm publish --dry-run",
        "publish:verify": "node ../../scripts/check-private-package-postpublish.mjs --scope @signalsafe --package @signalsafe/tree-spec-editor --version $npm_package_version",
        "pack:check": "node ../../scripts/check-package-tarball.mjs --tgz \"../../dist/reusable-npm/signalsafe-tree-spec-editor-$npm_package_version.tgz\" --expect package/dist/index.js --expect package/dist/index.d.ts --expect package/package.json --expect package/README.md",
        "smoke:external": "node ../../scripts/smoke-tree-spec-editor-external-consumer.mjs",
        "smoke:published": "node ../../scripts/smoke-tree-spec-editor-external-consumer.mjs --source registry",
        "prepublishOnly": "npm run build",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:monorepo": "cd ../../frontend && yarn vitest run --config vitest.tree-spec-editor.config.ts"
    },
    "dependencies": {
        "@signalsafe/tree-spec": "^0.3.1",
        "@signalsafe/tree-spec-editor-core": "^0.1.2",
        "@signalsafe/tree-spec-editor-react": "^0.1.2"
    },
    "peerDependencies": {
        "react": "^18.0.0",
        "react-bootstrap": "^2.10.0",
        "react-dom": "^18.0.0",
        "reactflow": "^11.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@types/react-test-renderer": "^18.3.0",
        "react": "^18.3.1",
        "react-bootstrap": "^2.10.2",
        "react-dom": "^18.3.1",
        "react-test-renderer": "^18.3.1",
        "reactflow": "^11.11.4",
        "typescript": "^5.4.2",
        "vitest": "^3.2.4"
    }
}
